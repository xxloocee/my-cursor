<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="my-cursor"
        Arguments=""
        InstallLocation="C:\Program Files\My Cursor\my-cursor">
    </Installer>
    <PackageInformation
        PackageName="my-cursor"
        PackageDisplayName="My Cursor"
        PublisherName="CN=My Cursor"
        PublisherDisplayName="My Cursor"
        Version="0.1.0.0"
        PackageDescription="My Cursor">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.cursor.wuxianxubei"
                Description="My Cursor"
                DisplayName="My Cursor"
                ExecutableName="my-cursor"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>My Cursor</DisplayName>
            <PublisherDisplayName>My Cursor</PublisherDisplayName>
            <Description>My Cursor</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="my-cursor.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
