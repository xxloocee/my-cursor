package client

import (
	"errors"
	"fmt"
	goruntime "runtime"

	"cursor/internal/certs"
	"cursor/internal/cursor"
)

// ApplyCursorSettings 用于处理与 ApplyCursorSettings 相关的逻辑。
func (s *ProxyService) ApplyCursorSettings() error {
	if s == nil || s.proxy == nil {
		return fmt.Errorf("proxy is not initialized")
	}
	rollback := func(primaryErr error, removeCurrentCA bool) error {
		var rollbackErr error
		if goruntime.GOOS == "darwin" {
			rollbackErr = errors.Join(rollbackErr, cursor.ClearSystemNodeExtraCACerts())
		}
		if err := cursor.ClearUserProxySettings(); err != nil {
			rollbackErr = errors.Join(rollbackErr, err)
		} else {
			s.setCursorSettingsApplied(false)
		}
		if removeCurrentCA && (goruntime.GOOS == "windows" || goruntime.GOOS == "darwin") {
			rollbackErr = errors.Join(rollbackErr, cursor.RemoveCACertInstalled(s.caCertPEM))
		}
		return errors.Join(primaryErr, rollbackErr)
	}
	s.caFileMu.Lock()
	caCertPath, err := cursor.EnsureCACertFile(s.caCertPEM, s.caFilePath)
	if err == nil {
		s.caFilePath = caCertPath
	}
	s.caFileMu.Unlock()
	if err != nil {
		return rollback(fmt.Errorf("ensure ca cert file: %w", err), false)
	}

	switch goruntime.GOOS {
	case "windows":
		if err := cursor.EnsureCACertInstalled(s.caCertPEM, caCertPath); err != nil {
			return rollback(fmt.Errorf("install ca cert: %w", err), true)
		}
		if err := cursor.RemoveCACertInstalled(certs.LegacyCACertPEM()); err != nil {
			return rollback(fmt.Errorf("remove legacy ca cert: %w", err), true)
		}
	case "darwin":
		if err := cursor.EnsureCACertInstalled(s.caCertPEM, caCertPath); err != nil {
			return rollback(fmt.Errorf("install ca cert: %w", err), true)
		}
		if err := cursor.RemoveCACertInstalled(certs.LegacyCACertPEM()); err != nil {
			return rollback(fmt.Errorf("remove legacy ca cert: %w", err), true)
		}
		if err := cursor.SetSystemNodeExtraCACerts(caCertPath); err != nil {
			return rollback(fmt.Errorf("set node extra ca certs: %w", err), true)
		}
	}

	if err := cursor.WriteUserProxySettings(cursor.ProxyURLFromListenAddr(s.proxy.Snapshot().ListenAddr)); err != nil {
		return rollback(err, true)
	}
	s.setCursorSettingsApplied(true)
	return nil
}

// ClearCursorSettings 用于处理与 ClearCursorSettings 相关的逻辑。
func (s *ProxyService) ClearCursorSettings() error {
	var clearErr error
	if goruntime.GOOS == "darwin" {
		if err := cursor.ClearSystemNodeExtraCACerts(); err != nil {
			clearErr = errors.Join(clearErr, err)
		}
	}
	if err := cursor.ClearUserProxySettings(); err != nil {
		clearErr = errors.Join(clearErr, err)
	} else {
		s.setCursorSettingsApplied(false)
	}
	if goruntime.GOOS == "windows" || goruntime.GOOS == "darwin" {
		if err := cursor.RemoveCACertInstalled(s.caCertPEM); err != nil {
			clearErr = errors.Join(clearErr, err)
		}
		if err := cursor.RemoveCACertInstalled(certs.LegacyCACertPEM()); err != nil {
			clearErr = errors.Join(clearErr, err)
		}
	}
	return clearErr
}

// GetDeviceID 用于处理与 GetDeviceID 相关的逻辑。
func (s *ProxyService) GetDeviceID() (string, error) {
	return cursor.GetDeviceID()
}
